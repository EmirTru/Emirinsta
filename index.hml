<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>Instagram</title>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
    <style>
        :root { --ig-bg: #fafafa; --ig-white: #ffffff; --ig-black: #262626; --ig-blue: #0095f6; --ig-gray: #8e8e8e; --ig-border: #dbdbdb; --font-stack: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { background-color: var(--ig-bg); font-family: var(--font-stack); overflow-x: hidden; }

        /* --- AUTH EKRANI --- */
        #auth-screen { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: white; z-index: 1000; display: flex; justify-content: center; align-items: center; }
        .auth-box { width: 100%; max-width: 350px; padding: 30px; text-align: center; }
        .logo-text { font-size: 3.5rem; font-weight: 500; margin-bottom: 30px; letter-spacing: -2px; }
        input { width: 100%; padding: 12px; margin-bottom: 8px; border: 1px solid var(--ig-border); border-radius: 4px; background: #fafafa; font-size: 0.8rem; }
        .btn-blue { width: 100%; padding: 12px; border: none; border-radius: 8px; background: var(--ig-blue); color: white; font-weight: 700; cursor: pointer; margin-top: 15px; }

        /* --- MAIN APP --- */
        #main-app { display: none; padding-top: 60px; padding-bottom: 60px; }
        .header { position: fixed; top: 0; width: 100%; height: 60px; background: white; border-bottom: 1px solid var(--ig-border); display: flex; justify-content: space-between; align-items: center; padding: 0 16px; z-index: 500; }
        .header .logo { font-size: 1.6rem; font-weight: 700; }
        .h-icons img { width: 24px; margin-left: 20px; }

        /* --- STORIES --- */
        .stories { height: 110px; background: white; border-bottom: 1px solid var(--ig-border); display: flex; align-items: center; padding: 0 10px; gap: 15px; overflow-x: auto; -webkit-overflow-scrolling: touch; }
        .stories::-webkit-scrollbar { display: none; }
        .story { min-width: 75px; text-align: center; }
        .s-circle { width: 68px; height: 68px; border-radius: 50%; padding: 3px; background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #bc1888); margin: 0 auto 5px; }
        .s-circle img { width: 100%; height: 100%; border-radius: 50%; border: 2px solid white; object-fit: cover; }
        .story p { font-size: 0.7rem; color: #262626; overflow: hidden; text-overflow: ellipsis; }

        /* --- FEED --- */
        .post { background: white; margin-bottom: 1px; border-bottom: 1px solid var(--ig-border); }
        .p-header { display: flex; align-items: center; padding: 12px; justify-content: space-between; }
        .p-user { display: flex; align-items: center; gap: 10px; font-weight: 600; font-size: 0.9rem; }
        .p-user img { width: 34px; height: 34px; border-radius: 50%; object-fit: cover; }
        .p-img img { width: 100%; display: block; }
        .p-actions { display: flex; justify-content: space-between; padding: 15px; }
        .p-actions .left img { width: 26px; margin-right: 15px; }
        .p-info { padding: 0 15px 15px; font-size: 0.9rem; }
        .p-likes { font-weight: 700; margin-bottom: 5px; }

        /* --- NAV --- */
        .nav { position: fixed; bottom: 0; width: 100%; height: 55px; background: white; border-top: 1px solid var(--ig-border); display: flex; justify-content: space-around; align-items: center; z-index: 500; }
        .nav img { width: 26px; }
        .profile-nav { width: 26px; height: 26px; border-radius: 50%; object-fit: cover; }
    </style>
</head>
<body>

    <!-- GİRİŞ EKRANI -->
    <div id="auth-screen">
        <div class="auth-box">
            <div class="logo-text">Instagram</div>
            <div id="login-form">
                <input type="email" id="email" placeholder="E-posta">
                <input type="password" id="pass" placeholder="Şifre">
                <button class="btn-blue" id="btn-login">Giriş Yap</button>
            </div>
        </div>
    </div>

    <!-- ANA UYGULAMA -->
    <div id="main-app">
        <div class="header">
            <div class="logo">Instagram</div>
            <div class="h-icons">
                <img src="https://img.icons8.com/material-outlined/24/000000/plus-2-math.png">
                <img src="https://img.icons8.com/material-outlined/24/000000/like.png">
                <img src="https://img.icons8.com/material-outlined/24/000000/sent.png">
            </div>
        </div>

        <div class="stories" id="story-row">
            <!-- Hikayeler buraya eklenecek -->
        </div>

        <div id="post-feed">
             <!-- Gönderiler buraya eklenecek -->
        </div>

        <div class="nav">
            <img src="https://img.icons8.com/material/24/000000/home--v1.png">
            <img src="https://img.icons8.com/material-outlined/24/000000/search--v1.png">
            <img src="https://img.icons8.com/material-outlined/24/000000/video-playlist.png">
            <img src="https://img.icons8.com/material-outlined/24/000000/shopping-bag.png">
            <img src="https://i.pravatar.cc/150?u=me" class="profile-nav" id="logout-btn">
        </div>
    </div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
        import { getAuth, signInWithEmailAndPassword, onAuthStateChanged, setPersistence, browserLocalPersistence, signOut } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-auth.js";
        import { getFirestore, collection, onSnapshot, query, orderBy } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore.js";

        // Firebase Ayarların
        const firebaseConfig = {
            apiKey: "AIzaSyBIK0LHEqw6gEi6fwWER4i6HK9Aoxr4ECk",
            authDomain: "emirinsta.firebaseapp.com",
            projectId: "emirinsta",
            storageBucket: "emirinsta.firebasestorage.app",
            messagingSenderId: "1054133758624",
            appId: "1:1054133758624:web:a7ec89a1e9cf350aafb7c5"
        };

        const app = initializeApp(firebaseConfig);
        const auth = getAuth(app);
        const db = getFirestore(app);

        // BENİ HATIRLA (Hafıza Ayarı)
        setPersistence(auth, browserLocalPersistence);

        const authScreen = document.getElementById('auth-screen');
        const mainApp = document.getElementById('main-app');

        // GİRİŞ YAP
        document.getElementById('btn-login').onclick = () => {
            const e = document.getElementById('email').value;
            const p = document.getElementById('pass').value;
            signInWithEmailAndPassword(auth, e, p).catch(err => alert("Hata: " + err.message));
        };

        // OTURUM KONTROL
        onAuthStateChanged(auth, (user) => {
            if (user) {
                authScreen.style.display = 'none';
                mainApp.style.display = 'block';
                loadContent();
            } else {
                authScreen.style.display = 'flex';
                mainApp.style.display = 'none';
            }
        });

        // İÇERİK YÜKLE
        function loadContent() {
            // Hikayeler (Sahte Veri)
            const stories = ["senin_hikayen", "emre_dev", "ayse_g", "yasin_34", "tech_news"];
            const row = document.getElementById('story-row');
            row.innerHTML = stories.map((s, i) => `
                <div class="story">
                    <div class="s-circle"><img src="https://i.pravatar.cc/150?u=${i}"></div>
                    <p>${s}</p>
                </div>
            `).join('');

            // Gönderiler (Firestore'dan)
            onSnapshot(query(collection(db, "posts"), orderBy("timestamp", "desc")), (snap) => {
                const feed = document.getElementById('post-feed');
                feed.innerHTML = '';
                snap.forEach(doc => {
                    const d = doc.data();
                    feed.innerHTML += `
                        <div class="post">
                            <div class="p-header">
                                <div class="p-user"><img src="https://i.pravatar.cc/150?u=${d.username}"> <span>${d.username}</span></div>
                                <img src="https://img.icons8.com/material-outlined/24/000000/more.png" style="width:20px">
                            </div>
                            <div class="p-img"><img src="${d.imageUrl}"></div>
                            <div class="p-actions">
                                <div class="left">
                                    <img src="https://img.icons8.com/material-outlined/26/000000/like.png">
                                    <img src="https://img.icons8.com/material-outlined/26/000000/speech-bubble.png">
                                    <img src="https://img.icons8.com/material-outlined/26/000000/sent.png">
                                </div>
                                <img src="https://img.icons8.com/material-outlined/26/000000/bookmark-ribbon.png">
                            </div>
                            <div class="p-info">
                                <div class="p-likes">1.250 beğenme</div>
                                <p><b>${d.username}</b> ${d.caption}</p>
                            </div>
                        </div>
                    `;
                });
            });
        }

        // Çıkış (Profil Resmine Basınca)
        document.getElementById('logout-btn').onclick = () => { if(confirm("Çıkış yap?")) signOut(auth); };
    </script>
</body>
</html>
